@page "/projects/{ProjectName}"

@switch (ProjectName)
{
    case "blazor":
        <BlazorComponents />
        break;
    case "devteam":
        <Devteam />
        break;
    case "bindery":
        <OptionA.Site.Projects.Bindery.Project />
        break;
    default:
        <h1 class="h3">Project not found</h1>
        <p>Sorry, we couldn't find the project you're looking for.</p>
        break;
}