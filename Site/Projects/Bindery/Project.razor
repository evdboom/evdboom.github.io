@using System.Collections.Generic

<div class="bindery-landing">
    <!-- Hero Section -->
    <section class="hero-section text-center py-5">
        <div class="container">
            <h1 class="display-3 fw-bold mb-3">Bindery</h1>
            <p class="lead mb-4">
                Markdown book authoring toolkit for writers and AI assistants
            </p>
            <p class="fs-5 mb-5">
                A powerful VS Code extension for typography formatting paired with an MCP server for full-text search and seamless AI integration
            </p>
            <div class="d-flex gap-3 justify-content-center flex-wrap">
                <a href="https://marketplace.visualstudio.com/items?itemName=option-a.bindery" target="_blank" class="btn btn-light btn-lg fw-bold">
                    VS Code Extension
                </a>
                <a href="https://github.com/evdboom/Bindery/releases" target="_blank" class="btn btn-outline-light btn-lg fw-bold">
                    Claude Desktop
                </a>
            </div>
        </div>
    </section>

    <!-- Problem Section -->
    <section class="py-5 bg-light">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6 mb-4 mb-lg-0">
                    <h2 class="h3 fw-bold mb-3">The Copy-Paste Problem</h2>
                    <p class="fs-5 mb-3">
                        Traditional AI-assisted writing often becomes a tedious loop:
                    </p>
                    <ul class="problem-section-list">
                        <li class="mb-3">
                            <i class="bi bi-arrow-right-circle-fill"></i>
                            <span class="ms-2">Write a chapter in your tool</span>
                        </li>
                        <li class="mb-3">
                            <i class="bi bi-arrow-right-circle-fill"></i>
                            <span class="ms-2">Copy it to ChatGPT / Claude</span>
                        </li>
                        <li class="mb-3">
                            <i class="bi bi-arrow-right-circle-fill"></i>
                            <span class="ms-2">Get feedback and paste it back</span>
                        </li>
                        <li class="mb-3">
                            <i class="bi bi-arrow-right-circle-fill"></i>
                            <span class="ms-2">Repeat endlessly...</span>
                        </li>
                    </ul>
                </div>
                <div class="col-lg-6">
                    <div class="solution-card p-4">
                        <h5 class="card-title fw-bold mb-3">Bindery Changes Everything</h5>
                        <p class="card-text mb-0">
                            Direct MCP integration means your AI assistant reads your book directly. 
                            No copy-paste. No context loss. Just write, collaborate, and watch your story come to life.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section class="py-5">
        <div class="container">
            <h2 class="text-center h2 fw-bold mb-5">Powerful Features</h2>
            <div class="row g-4">
                <div class="col-md-6 col-lg-4">
                    <div class="feature-card h-100 p-4 border-0 shadow-sm rounded">
                        <div class="feature-icon mb-3 feature-icon-primary">
                            ✨
                        </div>
                        <h5 class="fw-bold mb-3">Typography Formatting</h5>
                        <p class="text-muted mb-0">
                            Smart curly quotes, em-dashes, ellipses, and intelligent apostrophes automatically applied across your manuscript.
                        </p>
                    </div>
                </div>

                <div class="col-md-6 col-lg-4">
                    <div class="feature-card h-100 p-4 border-0 shadow-sm rounded">
                        <div class="feature-icon mb-3 feature-icon-secondary">
                            🔍
                        </div>
                        <h5 class="fw-bold mb-3">Full-Text Search</h5>
                        <p class="text-muted mb-0">
                            BM25 lexical search across all chapters and notes, with optional Ollama semantic reranking for deeper context discovery.
                        </p>
                    </div>
                </div>

                <div class="col-md-6 col-lg-4">
                    <div class="feature-card h-100 p-4 border-0 shadow-sm rounded">
                        <div class="feature-icon mb-3 feature-icon-primary">
                            📚
                        </div>
                        <h5 class="fw-bold mb-3">Multi-Format Export</h5>
                        <p class="text-muted mb-0">
                            Export to Markdown, DOCX, EPUB, or PDF with Pandoc and LibreOffice integration.
                        </p>
                    </div>
                </div>

                <div class="col-md-6 col-lg-4">
                    <div class="feature-card h-100 p-4 border-0 shadow-sm rounded">
                        <div class="feature-icon mb-3 feature-icon-secondary">
                            🌍
                        </div>
                        <h5 class="fw-bold mb-3">Multi-Language Support</h5>
                        <p class="text-muted mb-0">
                            Extensible dialect conversion and multi-language chapter labeling configured per project.
                        </p>
                    </div>
                </div>

                <div class="col-md-6 col-lg-4">
                    <div class="feature-card h-100 p-4 border-0 shadow-sm rounded">
                        <div class="feature-icon mb-3 feature-icon-primary">
                            🤖
                        </div>
                        <h5 class="fw-bold mb-3">AI Integration</h5>
                        <p class="text-muted mb-0">
                            Works with GitHub Copilot, Claude for VS Code, Codex, Claude Desktop, and Cowork.
                        </p>
                    </div>
                </div>

                <div class="col-md-6 col-lg-4">
                    <div class="feature-card h-100 p-4 border-0 shadow-sm rounded">
                        <div class="feature-icon mb-3 feature-icon-secondary">
                            📝
                        </div>
                        <h5 class="fw-bold mb-3">Version Tracking</h5>
                        <p class="text-muted mb-0">
                            Git integration for version control and progress snapshots, with structured diff viewing for uncommitted changes.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Components Section -->
    <section class="py-5 bg-light">
        <div class="container">
            <h2 class="text-center h2 fw-bold mb-5">Components</h2>
            <div class="row g-4">
                <!-- VS Code Extension -->
                <div class="col-lg-6">
                    <div class="component-card card border-0 shadow-sm h-100">
                        <div class="card-body p-5">
                            <h4 class="card-title fw-bold mb-3 component-card-title-primary">📦 VS Code Extension</h4>
                            <p class="card-text mb-3">
                                <strong>TypeScript</strong> | Available on the <a href="https://marketplace.visualstudio.com/items?itemName=option-a.bindery" target="_blank">VS Code Marketplace</a>
                            </p>
                            <p class="text-muted mb-3">
                                Provides typography formatting, chapter merge & export, dialect conversion, workspace configuration, and MCP integration for GitHub Copilot Chat.
                            </p>
                            <div class="d-flex gap-2 flex-wrap">
                                <span class="badge badge-light">Typography</span>
                                <span class="badge badge-light">Export</span>
                                <span class="badge badge-light">Formatting</span>
                                <span class="badge badge-light">Dialects</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- MCP Server -->
                <div class="col-lg-6">
                    <div class="component-card card border-0 shadow-sm h-100">
                        <div class="card-body p-5">
                            <h4 class="card-title fw-bold mb-3 component-card-title-secondary">⚙️ MCP Server (Node.js)</h4>
                            <p class="card-text mb-3">
                                <strong>TypeScript</strong> | Model Context Protocol server with pure Node.js
                            </p>
                            <p class="text-muted mb-3">
                                BM25 full-text search, optional Ollama reranking, multi-book support, version tracking with git integration, and container/mount awareness.
                            </p>
                            <div class="d-flex gap-2 flex-wrap">
                                <span class="badge badge-light">Search</span>
                                <span class="badge badge-light">MCP</span>
                                <span class="badge badge-light">Multi-book</span>
                                <span class="badge badge-light">Git</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Claude Desktop -->
                <div class="col-lg-12">
                    <div class="component-card card border-0 shadow-sm">
                        <div class="card-body p-5">
                            <h4 class="card-title fw-bold mb-3 component-card-title-primary">🚀 Claude Desktop Extension (.mcpb)</h4>
                            <p class="card-text mb-3">
                                Pre-packaged MCP server for one-click installation in Claude Desktop or Cowork
                            </p>
                            <p class="text-muted mb-3">
                                Download from <a href="https://github.com/evdboom/Bindery/releases" target="_blank">GitHub Releases</a> — no build step needed. Configure your book paths and you're ready to go.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Quick Start Section -->
    <section class="py-5">
        <div class="container">
            <h2 class="text-center h2 fw-bold mb-5">Quick Start</h2>
            <div class="row">
                <div class="col-lg-6 mb-4">
                    <div class="quickstart-item">
                        <h5 class="fw-bold mb-3">
                            <span class="badge bg-primary me-2">1</span>
                            VS Code Setup
                        </h5>
                        <ol class="ps-3">
                            <li class="mb-2">Install <a href="https://marketplace.visualstudio.com/items?itemName=option-a.bindery" target="_blank">Bindery extension</a> from Marketplace</li>
                            <li class="mb-2">Open your book folder in VS Code</li>
                            <li class="mb-2">Run <code>Bindery: Initialise Workspace</code></li>
                            <li class="mb-2">Run <code>Bindery: Register MCP Server</code></li>
                            <li>Tools available in Copilot Chat, Claude, or Codex</li>
                        </ol>
                    </div>
                </div>

                <div class="col-lg-6 mb-4">
                    <div class="quickstart-item">
                        <h5 class="fw-bold mb-3">
                            <span class="badge bg-primary me-2">2</span>
                            Claude Desktop Setup
                        </h5>
                        <ol class="ps-3">
                            <li class="mb-2">Download <code>bindery-mcp-*.mcpb</code> from <a href="https://github.com/evdboom/Bindery/releases" target="_blank">latest release</a></li>
                            <li class="mb-2">Open Claude Desktop → Settings → Extensions → Install from file</li>
                            <li class="mb-2">Configure Books field: <code>MyBook=C:\path\to\book</code></li>
                            <li class="mb-2">Optionally set Ollama URL for semantic reranking</li>
                            <li>Start using Bindery tools with Claude</li>
                        </ol>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Privacy Section -->
    <section class="py-5 bg-light">
        <div class="container">
            <div class="row">
                <div class="col-lg-8 mx-auto text-center">
                    <h3 class="h4 fw-bold mb-3">Your Privacy Matters</h3>
                    <p class="mb-4">
                        Bindery MCP is a local-first tool that respects your privacy. All operations run entirely on your machine with no external data collection.
                    </p>
                    <a href="projects/bindery/privacy" class="btn btn-outline-primary">
                        Read Privacy Policy
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer Section -->
    <section class="py-5 footer-section">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 mb-3 mb-md-0">
                    <h5 class="fw-bold mb-2">Bindery</h5>
                    <p class="text-muted mb-0">
                        Markdown book authoring for writers and AI assistants.
                    </p>
                </div>
                <div class="col-md-6 text-md-end">
                    <a href="https://github.com/evdboom/Bindery" target="_blank" class="btn btn-sm btn-outline-secondary me-2">
                        GitHub
                    </a>
                    <a href="https://marketplace.visualstudio.com/items?itemName=option-a.bindery" target="_blank" class="btn btn-sm btn-outline-secondary me-2">
                        VS Code
                    </a>
                    <a href="projects/bindery/privacy" class="btn btn-sm btn-outline-secondary">
                        Privacy
                    </a>
                </div>
            </div>
            <hr class="my-4">
            <div class="text-center text-muted small">
                <p class="mb-0">© 2026 Bindery. Licensed under MIT.</p>
            </div>
        </div>
    </section>
</div>
